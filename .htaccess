Options -Indexes
RewriteEngine On
RewriteBase /

# Prevent direct access to includes folder
RewriteRule ^includes/ - [F,L]

# Skip real files and directories
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Clean URL Routes
RewriteRule ^product/([a-zA-Z0-9_-]+)/?$ product.php?slug=$1 [QSA,L]
RewriteRule ^category/([a-zA-Z0-9_-]+)/?$ category.php?slug=$1 [QSA,L]
RewriteRule ^search/?$ index.php [QSA,L]
RewriteRule ^admin/?$ admin/index.php [L]
RewriteRule ^order-success/?$ order-success.php [QSA,L]
