Options -Indexes
RewriteEngine On
RewriteBase /

# Prevent direct access to includes folder
RewriteRule ^includes/ - [F,L]

# Skip real files and directories
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Clean URL Routes
RewriteRule ^category/([^/]+)/?$ category.php?slug=$1 [QSA,L]
RewriteRule ^product/([^/]+)/?$ product.php?slug=$1 [QSA,L]
RewriteRule ^search/?$ search.php [QSA,L]
RewriteRule ^admin/?$ admin/index.php [L]
RewriteRule ^order-success/?$ order-success.php [QSA,L]
